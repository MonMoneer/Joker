{
  "name": "@joker/server",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs --external:express --external:socket.io --external:cors",
    "start": "node dist/index.cjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@joker/engine": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "socket.io": "^4.8.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
